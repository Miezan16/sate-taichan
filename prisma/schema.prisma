generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUM untuk Role
enum Role {
  admin
  kasir
}

model User {
  id            Int         @id @default(autoincrement())
  username      String      @unique
  password_hash String
  role          Role
  transaksi     Transaksi[] // Relasi kasir ke transaksi
}

model Menu {
  id              Int             @id @default(autoincrement())
  nama            String
  deskripsi       String?
  protein         String          @default("Ayam")
  harga           Int
  stok            Int             @default(100) // Tambahan stok
  level_pedas_min Int             @default(0)
  level_pedas_max Int             @default(5)
  kalori          Int             @default(0)   // Tambahan kalori
  favorit         Boolean         @default(false)
  tersedia        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  TransaksiItem   TransaksiItem[] // Relasi menu ke item transaksi
}

model Transaksi {
  id           Int             @id @default(autoincrement())
  kasir_id     Int
  total_harga  Int
  uang_bayar   Int
  kembalian    Int
  tanggal      DateTime        @default(now())
  kasir        User            @relation(fields: [kasir_id], references: [id])
  items        TransaksiItem[]
}

model TransaksiItem {
  id           Int       @id @default(autoincrement())
  transaksi_id Int
  menu_id      Int
  jumlah       Int
  harga_satuan Int
  transaksi    Transaksi @relation(fields: [transaksi_id], references: [id])
  menu         Menu      @relation(fields: [menu_id], references: [id])
}

model Cabang {
  id          Int      @id @default(autoincrement())
  nama_cabang String
  alamat      String
  link_maps   String?
}